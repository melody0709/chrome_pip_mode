{
  "manifest_version": 3,
  "name": "Floating Video Resizer",
  "description": "Adds four-corner resizing and drag support for Bilibili and YouTube's floating player.",
  "version": "0.3.0",
  "icons": {
    "128": "assets/icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.bilibili.com/*",
    "https://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.bilibili.com/video/*",
        "https://www.bilibili.com/bangumi/play/*",
        "https://www.youtube.com/watch?*",
        "https://www.youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}